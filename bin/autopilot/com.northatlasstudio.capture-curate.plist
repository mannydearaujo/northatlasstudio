<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Placeholder __REPO__ is replaced by bin/autopilot-install.sh -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.northatlasstudio.capture-curate</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO__/bin/run-capture-curate.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>6</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__REPO__/.ops/logs/autopilot.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO__/.ops/logs/autopilot.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
